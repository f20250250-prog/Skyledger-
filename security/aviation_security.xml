<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_aviation" model="ir.module.category">
        <field name="name">Skyledger Aviation ERP</field>
        <field name="sequence">100</field>
    </record>

    <record id="privilege_aviation_management" model="res.groups.privilege">
        <field name="name">Aviation Operations</field>
        <field name="category_id" ref="module_category_aviation"/>
    </record>

    <record id="group_aviation_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="privilege_aviation_management"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_aviation_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="privilege_aviation_management"/>
        <field name="implied_ids" eval="[(4, ref('aviation_erp.group_aviation_user'))]"/>
    </record>

    <record id="group_aviation_analyst" model="res.groups">
        <field name="name">Revenue Analyst</field>
        <field name="privilege_id" ref="privilege_aviation_management"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>