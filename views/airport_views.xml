<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_aviation_airport_list" model="ir.ui.view">
        <field name="name">aviation.airport.list</field>
        <field name="model">aviation.airport</field>
        <field name="arch" type="xml">
            <list string="Airports" default_order="iata_code">
                <field name="iata_code" string="IATA"/>
                <field name="icao_code" string="ICAO"/>
                <field name="name"/>
                <field name="city"/>
                <field name="country_id"/>
                <field name="elevation_ft"/>
                <field name="active" invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_aviation_airport_form" model="ir.ui.view">
        <field name="name">aviation.airport.form</field>
        <field name="model">aviation.airport</field>
        <field name="arch" type="xml">
            <form string="Airport">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_flight_route_list)d" type="action"
                                class="oe_stat_button" icon="fa-route"
                                context="{'default_origin_airport_id': id}">
                            <field name="origin_route_ids" widget="statinfo" string="Dep. Routes"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="iata_code" placeholder="IATA Code (3 chars)" class="o_field_highlight"/>
                        </h1>
                        <h2>
                            <field name="name" placeholder="Airport Name"/>
                        </h2>
                    </div>
                    <group>
                        <group string="Identification">
                            <field name="icao_code"/>
                            <field name="city"/>
                            <field name="country_id"/>
                            <field name="timezone"/>
                        </group>
                        <group string="Characteristics">
                            <field name="elevation_ft"/>
                            <field name="terminal_count"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Geo Coordinates (for Map View)">
                        <group>
                            <field name="partner_latitude" string="Latitude"/>
                            <field name="partner_longitude" string="Longitude"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_aviation_airport_search" model="ir.ui.view">
        <field name="name">aviation.airport.search</field>
        <field name="model">aviation.airport</field>
        <field name="arch" type="xml">
            <search string="Search Airports">
                <field name="iata_code" string="IATA Code"/>
                <field name="name"/>
                <field name="city"/>
                <field name="country_id"/>
                
                <separator/>
                
                <filter name="active" string="Active" domain="[('active','=',True)]"/>
                <filter name="inactive" string="Archived" domain="[('active','=',False)]"/>
                
                <separator/>

                <filter name="group_country" string="Country" context="{'group_by': 'country_id'}"/>
                <filter name="group_city" string="City" context="{'group_by': 'city'}"/>
            </search>
        </field>
    </record>

    <record id="action_aviation_airport" model="ir.actions.act_window">
        <field name="name">Airports</field>
        <field name="res_model">aviation.airport</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_aviation_airport_search"/>
    </record>

</odoo>