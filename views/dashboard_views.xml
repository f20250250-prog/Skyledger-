<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_aviation_dashboard_pivot" model="ir.ui.view">
        <field name="name">aviation.dashboard.kpi.pivot</field>
        <field name="model">aviation.dashboard.kpi</field>
        <field name="arch" type="xml">
            <pivot string="Aviation Performance Analysis" sample="1">
                <field name="route_id" type="row"/>
                <field name="month" type="col"/>
                <field name="rasm" type="measure"/>
                <field name="casm" type="measure"/>
                <field name="total_revenue" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_aviation_dashboard_graph" model="ir.ui.view">
        <field name="name">aviation.dashboard.kpi.graph</field>
        <field name="model">aviation.dashboard.kpi</field>
        <field name="arch" type="xml">
            <graph string="Revenue vs Cost Trends" type="line" sample="1">
                <field name="month"/>
                <field name="total_revenue" type="measure"/>
                <field name="total_cost" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_aviation_dashboard_search" model="ir.ui.view">
        <field name="name">aviation.dashboard.kpi.search</field>
        <field name="model">aviation.dashboard.kpi</field>
        <field name="arch" type="xml">
            <search>
                <field name="route_id"/>
                <field name="route_name"/>
                <field name="month"/>
                <group>
                    <filter string="Route" name="group_by_route" context="{'group_by': 'route_id'}"/>
                    <filter string="Month" name="group_by_month" context="{'group_by': 'month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_aviation_dashboard" model="ir.actions.act_window">
        <field name="name">Executive Dashboard</field>
        <field name="res_model">aviation.dashboard.kpi</field>
        <field name="view_mode">graph,pivot</field>
        <field name="search_view_id" ref="view_aviation_dashboard_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No data available for the dashboard yet.
            </p>
            <p>
                Ensure flights are marked as 'Completed' to see KPI calculations.
            </p>
        </field>
    </record>


</odoo>